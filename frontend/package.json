{
  "name": "local-review",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "local-review": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "npm run build:frontend",
    "dev": "vite --config vite.config.ts --open",
