    "commander": "12.1.0",
    "express": "4.21.0",
    "lucide-react": "^1.24.0",
    "motion": "^12.42.2",
    "open": "10.1.0",
    "react": "18.3.1",
    "react-diff-view": "3.2.1",
    "react-dom": "18.3.1",
    "refractor": "4.8.1",
    "simple-git": "3.27.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "5.0.0",
    "@types/node": "22.9.0",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.3.4",
    "@vitest/browser": "^2.1.9",
